<help:HelpContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="clr-namespace:LMCUI.Pages"
             xmlns:help="clr-namespace:LMCUI.Pages.Help"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="LMCUI.Pages.Help.HelpPage">
    <Grid Margin="60, 30">
        <ScrollViewer>
            <StackPanel Orientation="Vertical">
                <TextBlock>帮助页面加载失败或正在加载，请稍后。</TextBlock>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</help:HelpContentPage>
