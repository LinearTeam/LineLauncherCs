<pages:PageBase xmlns="https://github.com/avaloniaui"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:ui="using:FluentAvalonia.UI.Controls"
                xmlns:i18n="clr-namespace:LMCUI.I18n"
                xmlns:pages="clr-namespace:LMCUI.Pages"
                mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
                x:Class="LMCUI.Pages.VersionManagePage.VersionDetailPage">
    <Grid Margin="60, 20, 40, 30">
        <ScrollViewer>
            <StackPanel Orientation="Vertical" Spacing="8">
                <TextBlock Name="VersionNameText" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Name="VersionTypeText" Opacity="0.85" />
                <TextBlock Name="VersionStatusText" Opacity="0.85" />
                <TextBlock Name="VersionRootText" TextWrapping="Wrap" />
                <TextBlock Name="VersionDirectoryText" TextWrapping="Wrap" />
                <ui:FASettingsExpander Header="{i18n:I18nBinding Key=Pages.VersionDetailPage.Placeholder.Header}"
                                       Description="{i18n:I18nBinding Key=Pages.VersionDetailPage.Placeholder.Description}"
                                       IconSource="Info" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</pages:PageBase>
