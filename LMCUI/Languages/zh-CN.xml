<?xml version="1.0" encoding="utf-8"?>
<Localization>
    <MainWindow>
        <Title>Line Launcher</Title>
        <NavItems>
            <LaunchPage>启动</LaunchPage>
            <VersionManagePage>版本管理</VersionManagePage>
            <TaskPage>任务管理</TaskPage>
            <DownloadPage>下载</DownloadPage>
            <DownloadMinecraftPage>下载游戏</DownloadMinecraftPage>
            <DownloadModPage>下载模组</DownloadModPage>
            <AccountPage>账号管理</AccountPage>
            <SettingsPage>设置</SettingsPage>
            <HelpPage>帮助</HelpPage>
        </NavItems>
    </MainWindow>
    
    <Pages>
        <AccountPage>
            <Title>账户管理</Title>
            <AccountListExpander>
                <Header>账户列表</Header>
                <Description>启动器中已经存储的账户</Description>
                <NoAccountsDescription>当前没有任何账户，你可以在下方添加一个新账户</NoAccountsDescription>
                <AccountTypeSuffix>
                    <Microsoft> (微软账户)</Microsoft>
                    <Offline> (离线账户)</Offline>
                    <Authlib> (第三方账户)</Authlib>
                </AccountTypeSuffix>
                <CopyUuidText> 复制 UUID</CopyUuidText>
                <CopyUsernameText> 复制用户名</CopyUsernameText>
            </AccountListExpander>
            <AddAccountExpander>
                <Header>添加账户</Header>
                <Description>添加一个新的 Microsoft 、离线或第三方 Yggdrasil 认证服务器账户</Description>
                <AddButtonText> 添加</AddButtonText>
            </AddAccountExpander>
            <AddAccountWizard>
                <Title>添加账户向导</Title>
                <CloseButton>关闭</CloseButton>
                <PreviousButton>上一步</PreviousButton>
                <NextButton>下一步</NextButton>
                <FinishButton>完成</FinishButton>
                <Steps>
                    <IndexStep>
                        <Title>选择账户类型</Title>
                        <AccountTypes>
                            <Microsoft>
                                <Name>微软账户</Name>
                                <Description>可以进入启用了正版验证的服务器。</Description>
                            </Microsoft>
                            <Offline>
                                <Name>离线账户</Name>
                                <Description>仅能进入未开启正版验证的服务器。</Description>
                            </Offline>
                            <Authlib>
                                <Name>第三方账户</Name>
                                <Description>可以加入使用第三方 Yggdrasil 验证的服务器。</Description>
                            </Authlib>
                        </AccountTypes>
                    </IndexStep>
                    <OfflineStep>
                        <Title>添加离线账户</Title>
                        <Watermarks>
                            <GameId>游戏ID...</GameId>
                            <UUID>UUID (可选，为空将由启动器自动生成)</UUID>
                        </Watermarks>
                        <ValidationMessages>
                            <EmptyGameId>请输入游戏 ID！</EmptyGameId>
                            <InvalidUUID>无效的 UUID！</InvalidUUID>
                        </ValidationMessages>
                        <GameIdWarnStep>
                            <Title>添加离线账户</Title>
                            <WarningMessage>您的 Minecraft 用户名应当仅包含数字、字母、下划线，并且小于16个字符。否则有可能导致无法进入单人存档、服务器。</WarningMessage>
                            <Confirmation>是否继续？</Confirmation>
                        </GameIdWarnStep>
                    </OfflineStep>
                    <MicrosoftStep>
                        <Title>添加微软账户</Title>
                        <Content>接下来你将进行微软登录，点击“下一步”后，你将跳转到登录链接，并在浏览器内完成微软登录，随后启动器会读取登录后返回的授权码，并进行身份验证。</Content>
                    </MicrosoftStep>
                    <MicrosoftOAuthStep>
                        <LinkMessage>请点击下方按钮跳转到登录页面，随后使用 Microsoft 账号登录，并授权 LMC 访问您的账户信息。您必须在启动器运行的设备上完成这一步。</LinkMessage>
                        <StepMessage>({0} / {1}) {2}</StepMessage>
                        <WaitingForLoginMessage>(1 / 6) 等待用户登录</WaitingForLoginMessage>
                        <ErrorMessage>登录发生错误，请检查网络或使用代理：{0}</ErrorMessage>
                        <NoMinecraftProfileMessage>您登录的微软账户并没有 Minecraft 档案信息，请确保您购买了游戏，并已于 Minecraft.net 新建档案。</NoMinecraftProfileMessage>
                        <CopyLinkButton>复制链接</CopyLinkButton>
                        <OpenLinkButton>打开网页</OpenLinkButton>
                        <CompleteMessage>您已完成登录！现在点击“完成”，即可将账户添加到 LMC 。</CompleteMessage>
                    </MicrosoftOAuthStep>
                </Steps>
            </AddAccountWizard>
        </AccountPage>
        <SettingsPage>
            <Title>设置</Title>
            <GameSettingsPageNav>
                <Header>游戏设置</Header>
                <Description>与游戏的下载、启动等相关的设置</Description>
            </GameSettingsPageNav>
            <LauncherSettingsPageNav>
                <Header>启动器设置</Header>
                <Description>管理启动器的行为，如启动器主题、更新策略等。</Description>
            </LauncherSettingsPageNav>
            <GameSettingsPage>
                <Title>游戏设置</Title>
                <JavaRuntime>
                    <Title>Java 运行时</Title>
                    <JavaListExpander>
                        <Header>Java 列表</Header>
                        <EmptyHeader>当前没有任何 Java</EmptyHeader>
                        <Description>查看启动器中存储的所有 Java 运行时</Description>
                        <JavaListItem>
                            <SelectButton>选择</SelectButton>
                            <Enabled>已启用</Enabled>
                        </JavaListItem>
                    </JavaListExpander>
                    <ImportExpander>
                        <Header>导入 Java</Header>
                        <Description>将系统中的 Java 运行时导入上方的列表</Description>
                        <Footer>
                            <SearchButton>搜索 Java</SearchButton>
                        </Footer>
                        <ChooseJavaDialog>
                            <Title>请选择 Java 可执行文件</Title>
                        </ChooseJavaDialog>
                        <StatusText>
                            <SearchProgress>{2} ({0} / {1})</SearchProgress>
                            <SearchSuccess>搜索成功！</SearchSuccess>
                            <SearchFailed>搜索失败：{0}</SearchFailed>
                            <AddSuccess>添加成功！</AddSuccess>
                            <AddFailed>错误：{0}</AddFailed>
                        </StatusText>
                    </ImportExpander>
                    <AutoSelectExpander>
                        <Header>自动选择 Java</Header>
                        <Description>让启动器自动选择启动游戏所需的 Java 运行时 (这将无视选择的 Java)</Description>
                        <Footer>
                            <ToggleSwitchButton>
                                <OnContent>启用</OnContent>
                                <OffContent>禁用</OffContent>
                            </ToggleSwitchButton>
                        </Footer>
                    </AutoSelectExpander>
                </JavaRuntime>
            </GameSettingsPage>
            <LauncherSettingsPage>
                <Title>启动器设置</Title>
                <AppearanceSettings>
                    <Title>外观设置</Title>
                    <LanguageExpander>
                        <Header>语言设置</Header>
                        <Description>调整启动器界面使用的语言，重启生效。</Description>
                        <RestartTeachingTip>
                            <Title>重启确认</Title>
                            <Subtitle>更改语言需要重启启动器以应用，是否立即重启？</Subtitle>
                            <CloseButtonText>稍后重启</CloseButtonText>
                            <RestartButtonText>立即重启</RestartButtonText>
                        </RestartTeachingTip>
                    </LanguageExpander>
                </AppearanceSettings>
            </LauncherSettingsPage>
        </SettingsPage>

        <LaunchPage>
            <Title>启动</Title>
            <WelcomeMessage>欢迎使用 Line Launcher</WelcomeMessage>
        </LaunchPage>

        <DownloadMinecraftPage>
            <Title>下载游戏</Title>
            <Filters>
                <Title>过滤</Title>
                <Release>正式版</Release>
                <Snapshot>快照版</Snapshot>
                <AprilFools>愚人节版</AprilFools>
                <Old>远古版</Old>
            </Filters>
            <Latest>
                <ReleaseHeader>最新正式版</ReleaseHeader>
                <SnapshotHeader>最新快照版</SnapshotHeader>
            </Latest>
            <Search>
                <Watermark>搜索版本 ID...</Watermark>
            </Search>
            <Types>
                <Release>正式版</Release>
                <Snapshot>快照版</Snapshot>
                <AprilFools>愚人节版</AprilFools>
                <Old>远古版</Old>
            </Types>
            <Dialog>
                <Title>版本信息 - {0}</Title>
                <CloseButton>关闭</CloseButton>
                <VersionId>版本 ID：{0}</VersionId>
                <VersionType>版本类型：{0}</VersionType>
                <ReleaseTime>发布时间：{0}</ReleaseTime>
                <Placeholder>原版下载安装流程暂未在此页面实现，当前仅提供版本浏览、搜索与筛选。</Placeholder>
            </Dialog>
            <Empty>
                <NoMatchingVersions>当前没有符合条件的版本。</NoMatchingVersions>
            </Empty>
            <Errors>
                <LoadFailedTitle>加载版本列表失败</LoadFailedTitle>
                <LoadFailedContent>获取版本清单失败：{0}</LoadFailedContent>
            </Errors>
            <Loading>正在加载版本列表...</Loading>
        </DownloadMinecraftPage>

        <TaskPage>
            <Title>任务管理</Title>
            <CancelButton>取消</CancelButton>
            <ConfirmButton>确定</ConfirmButton>
        </TaskPage>

        <VersionManagePage>
            <Title>版本管理</Title>
            <CommandBar>
                <InstallVersion>安装版本</InstallVersion>
                <SwitchMinecraftFolder>切换 .minecraft 文件夹</SwitchMinecraftFolder>
            </CommandBar>
            <CurrentRoot>
                <Header>当前游戏目录</Header>
                <Description>当前正在查看的 .minecraft 目录</Description>
                <VersionCount>共 {0} 个版本</VersionCount>
            </CurrentRoot>
            <RootDialog>
                <Title>选择 .minecraft 文件夹</Title>
                <Add>添加</Add>
                <Delete>删除</Delete>
                <Cancel>取消</Cancel>
                <Confirm>确定</Confirm>
                <PickFolderTitle>请选择 .minecraft 文件夹</PickFolderTitle>
            </RootDialog>
            <VersionType>
                <Release>正式版</Release>
                <Snapshot>快照版</Snapshot>
                <AprilFools>愚人节版</AprilFools>
                <Old>远古版</Old>
                <Error>错误版本</Error>
                <UnknownClientVersion>未知版本</UnknownClientVersion>
            </VersionType>
            <VersionStatus>
                <Valid>版本结构正常</Valid>
                <MissingJar>错误：缺少版本 JAR</MissingJar>
                <MissingJson>错误：缺少版本 JSON</MissingJson>
                <InvalidJson>错误：版本 JSON 格式无效</InvalidJson>
            </VersionStatus>
            <InvalidVersions>
                <Title>检测到异常版本</Title>
                <Content>以下版本存在异常：{0}</Content>
            </InvalidVersions>
            <EmptyState>
                <NoRootHeader>未选择游戏目录</NoRootHeader>
                <NoRootDescription>请先通过顶部命令栏选择一个 .minecraft 文件夹。</NoRootDescription>
                <NoRootPath>当前没有已选中的游戏目录。</NoRootPath>
                <NoRootVersions>当前没有可用的游戏目录，因此无法显示版本列表。</NoRootVersions>
                <NoVersions>当前目录下没有可识别的版本。</NoVersions>
                <Loading>正在扫描版本...</Loading>
            </EmptyState>
            <Errors>
                <SwitchRootTitle>切换目录失败</SwitchRootTitle>
                <SwitchRootContent>切换 .minecraft 文件夹失败：{0}</SwitchRootContent>
                <AddRootTitle>添加目录失败</AddRootTitle>
                <AddRootContent>添加 .minecraft 文件夹失败：{0}</AddRootContent>
                <ScanFailedTitle>扫描版本失败</ScanFailedTitle>
                <ScanFailedContent>扫描版本失败：{0}</ScanFailedContent>
            </Errors>
        </VersionManagePage>
        <VersionDetailPage>
            <Title>版本详情 - {0}</Title>
            <Status>状态：{0}</Status>
            <RootPath>游戏目录：{0}</RootPath>
            <VersionDirectory>版本目录：{0}</VersionDirectory>
            <Placeholder>
                <Header>详情页开发中</Header>
                <Description>当前版本详情页暂未实现详细内容，后续会在这里展示更完整的版本信息与操作。</Description>
            </Placeholder>
        </VersionDetailPage>

        <HelpPage>
            <Title>帮助中心</Title>
            <LoadingFailedTip>
                <Title>帮助文件加载失败</Title>
                <Content>帮助文件加载失败，若持续出现请于 设置 - 关于 中的反馈渠道反馈问题。</Content>
                <ErrorPrefix>错误信息：</ErrorPrefix>
            </LoadingFailedTip>
        </HelpPage>

        <AboutPage>
            <Title>关于</Title>
            <AboutLauncherExpander>
                <Header>关于 Line (Minecraft) Launcher</Header>
                <VersionDescription>版本 {0}-{1} Build-{2}</VersionDescription>
            </AboutLauncherExpander>
            <Author>
                <Name>Huangyu (皇鱼)</Name>
                <Description>LMC C#版的主要作者与维护者。</Description>
                <GitHub>GitHub</GitHub>
                <Blog>Huangyu's Blog</Blog>
            </Author>
        </AboutPage>

        <SettingsPage>
            <AboutPageNav>
                <Header>关于</Header>
                <Description>关于 Line (Minecraft) Launcher</Description>
            </AboutPageNav>
        </SettingsPage>
    </Pages>
    <Messages>
        <JavaManager>
            <SearchJava>
                <Progress>
                    <Variables>正在搜索环境变量</Variables>
                    <Registry>正在搜索注册表(仅 Windows)</Registry>
                    <StandardPaths>正在搜索 Java 默认安装路径</StandardPaths>
                    <MinecraftRuntime>正在搜索 Minecraft 官方启动器目录下的 Java</MinecraftRuntime>
                    <CurrentDir>正在搜索启动器目录下的 Java</CurrentDir>
                </Progress>
            </SearchJava>
        </JavaManager>
        <AccountManager>
            <AddAccount>
                <Duplicate>该账户已存在，不能重复添加</Duplicate>
                <Success>
                    <Title>添加成功</Title>
                    <Content>您已成功添加{0}账户，欢迎回来 {1}！</Content>
                </Success>
                <Failed>
                    <Title>添加失败</Title>
                    <Content>添加账户失败：{0}</Content>
                </Failed>
            </AddAccount>
            <OAuth>
                <Steps>
                    <WaitForCode>
                        <Message>等待用户登录</Message>
                    </WaitForCode>
                    <GetAccessToken>
                        <Message>获取访问令牌</Message>
                    </GetAccessToken>
                    <XBLAuthorize>
                        <Message>Xbox Live 身份验证</Message>
                    </XBLAuthorize>
                    <XSTSAuthorize>
                        <Message>XSTS 身份验证</Message>
                    </XSTSAuthorize>
                    <MinecraftAuthorize>
                        <Message>Minecraft 身份验证</Message>
                    </MinecraftAuthorize>
                    <ValidateMinecraft>
                        <Message>验证 Minecraft 账户</Message>
                    </ValidateMinecraft>
                </Steps>
            </OAuth>
        </AccountManager>
        <AccountPage>
            <Errors>
                <FailedToRefreshAccountList>
                    <Title>错误</Title>
                    <Content>无法刷新账户列表：{0}</Content>
                </FailedToRefreshAccountList>
            </Errors>
        </AccountPage>
    </Messages>
    <Enums>
        <AccountType>
            <Offline>离线</Offline>
            <Microsoft>微软</Microsoft>
            <Authlib>第三方</Authlib>
        </AccountType>
    </Enums>
</Localization>
